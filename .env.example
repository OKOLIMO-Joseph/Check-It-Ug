# Africa's Talking (Optional for SMS)
AT_API_KEY=
AT_USERNAME=

# Admin
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# App
ENVIRONMENT=development