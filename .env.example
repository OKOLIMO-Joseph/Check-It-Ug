# Google Gemini API (Free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/checkitug

# Redis
REDIS_URL=redis://redis:6379

# Twilio (Optional for WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
